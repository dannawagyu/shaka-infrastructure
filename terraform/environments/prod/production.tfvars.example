# Example only. Copy to production.local.tfvars and fill real values locally.
# production.local.tfvars is ignored by git. Do not commit real secrets.

aws_region  = "ap-northeast-2"
environment = "prod"

# Existing fixed-IP/domain Shaka production app host.
# Production Terraform references this host; it must not create a replacement EC2 instance.
existing_app_instance_id        = "i-xxxxxxxxxxxxxxxxx"
existing_app_security_group_id = "sg-xxxxxxxxxxxxxxxxx"

# Terraform-managed private RDS subnets inside the existing app VPC.
# Choose non-overlapping CIDRs within the existing VPC CIDR.
availability_zones   = ["ap-northeast-2a", "ap-northeast-2c"]
private_subnet_cidrs = ["10.42.10.0/24", "10.42.11.0/24"]

# RDS bootstrap credentials. Keep these in local ignored files or GitHub production secrets.
database_name     = "shaka"
db_engine_version = "8.0"
db_username       = "shaka_app_admin"
db_password       = "CHANGE_ME_IN_SECRET_STORE"
