aws_region         = "ap-northeast-2"
environment        = "prod"
vpc_id             = "vpc-xxxxxxxx"
public_subnet_id   = "subnet-xxxxxxxx"
private_subnet_ids = ["subnet-yyyyyyyy", "subnet-zzzzzzzz"]
operator_ssh_cidr  = "203.0.113.10/32"
ssh_key_name       = "shaka-production"
app_ami_id         = "ami-xxxxxxxxxxxxxxxxx"
app_instance_type  = "t3.micro"
database_name      = "shaka"
db_username        = "shaka_app"
db_password        = "CHANGE_ME_IN_SECRET_STORE"
